# memo-fish — runtime configuration. real values live in fly secrets; this file
# is the inventory of what variables exist and where their authoritative copy is.
# See memo-docs/standards/secrets.md.

# auth key required to POST /ingest. constant-time compared against X-Auth-Key.
# real value: fly secret on app `memo-fish`. local dev: any 32+ char random string.
MEMO_FISH_INGEST_KEY=

# auth key required to GET /download/:date. kept separate from ingest key so
# either can rotate without disturbing the other.
# real value: fly secret on app `memo-fish`. local dev: any 32+ char random string.
MEMO_FISH_DOWNLOAD_KEY=

# days of NDJSON kept on the volume before writer prunes them.
# real value: fly [env]. local dev: 7.
MEMO_FISH_RETENTION_DAYS=7

# directory holding data-YYYY-MM-DD.jsonl files.
# real value: fly [env] = /data (mount point). local dev: ./data.
MEMO_FISH_DATA_DIR=/data

# public listener (ingest / download / status).
# real value: fly [env] = 0.0.0.0:8080. local dev: 127.0.0.1:8080.
MEMO_FISH_PUBLIC_BIND=0.0.0.0:8080

# metrics-only listener on mesh0. set to empty string to disable when running
# without WG (e.g. local dev).
# real value: fly [env] = 10.66.0.4:9091. local dev: empty.
MEMO_FISH_METRICS_BIND=10.66.0.4:9091

# channel capacity between ingest handlers and the writer task. excess returns 429.
# real value: fly [env] = 10000. local dev: 10000.
MEMO_FISH_QUEUE_CAP=10000

# --- universal observability env vars (see memo-docs/standards/observability.md) ---

# log floor; trace/debug/info/warn/error.
LOG_LEVEL=info

# deployment env tag, baked into log fields and /status response.
# real value: fly [env] = prod. local dev: dev.
MEMO_ENV=dev

# semver-ish tag, injected by CI as docker --build-arg. local dev: leave empty.
MEMO_VERSION=

# short git SHA, injected by CI as docker --build-arg. local dev: leave empty.
MEMO_BUILD=

# --- WireGuard mesh0 material (only used inside the fly container) ---
# Authoritative copies live in memo-ops .env / /etc/wireguard on each peer.
# Required at container start; entrypoint.sh refuses to start without these.

WG_PRIVATE_KEY=
WG_PEER_US_PUBLIC=
WG_PEER_HK_PUBLIC=
